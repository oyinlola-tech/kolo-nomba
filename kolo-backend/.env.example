# Database
DATABASE_URL=postgresql://postgres:YOUR_DATABASE_PASSWORD@localhost:5432/kolo

# JWT Authentication
JWT_SECRET=YOUR_JWT_SECRET_KEY
JWT_REFRESH_SECRET=YOUR_JWT_REFRESH_SECRET_KEY
PORT=4000
NODE_ENV=development

# CORS Configuration - Only allow trusted domains
CORS_ORIGIN=https://kolo.telente.site,https://admin.kolo.telente.site

# Rate Limiting
RATE_LIMIT_MAX=100
LOG_LEVEL=info

# Nomba Payment Integration
NOMBA_API_KEY=YOUR_NOMBA_API_KEY
NOMBA_SECRET_KEY=YOUR_NOMBA_SECRET_KEY
NOMBA_ACCOUNT_ID=YOUR_NOMBA_ACCOUNT_ID
NOMBA_WEBHOOK_SECRET=YOUR_NOMBA_WEBHOOK_SECRET
NOMBA_BASE_URL=https://api.nomba.com/v1

# Super Admin - SET by deployment script, NOT in .env
# SUPER_ADMIN_EMAIL=admin@kolo.app
# SUPER_ADMIN_PASSWORD=YOUR_SUPER_ADMIN_PASSWORD

# Frontend URLs
FRONTEND_URL=https://kolo.telente.site
ADMIN_FRONTEND_URL=https://admin.kolo.telente.site

# Email Configuration
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_WHATSAPP_NOTIFICATIONS=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_smtp_app_password
SMTP_FROM_EMAIL=noreply@kolo.app
SMTP_FROM_NAME=Kolo
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY=60000

# Redis Configuration
REDIS_HOST=redis://localhost:6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
REDIS_DB=0
QUEUE_PREFIX=KOLO

# SMS Provider
SMS_PROVIDER=
SMS_API_KEY=
SMS_API_SECRET=

# WhatsApp Provider
WHATSAPP_PROVIDER=
WHATSAPP_API_KEY=

# Application Configuration
APP_NAME=Kolo
APP_LOGO_URL=
APP_FRONTEND_URL=https://kolo.telente.site
APP_SUPPORT_EMAIL=support@kolo.app
APP_PRIVACY_URL=https://kolo.app/privacy
APP_TERMS_URL=https://kolo.app/terms
PRIMARY_COLOR=#00A86B
SECONDARY_COLOR=#1F2937
