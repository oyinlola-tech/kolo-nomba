# =============================================================================
# Kolo Backend - Production Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all values before deployment.
# NEVER commit the actual .env file to version control.

# =============================================================================
# Database Configuration
# =============================================================================
# Required. PostgreSQL connection string with SSL for production:
#   DATABASE_URL=postgresql://user:password@host:5432/kolo?schema=public&ssl=true&sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/kolo?schema=public
# Optional. Prisma connection pool size (default: 10). Increase for higher concurrency.
PRISMA_POOL_SIZE=10
# Set to true to auto-run migrations on startup (use with caution in production).
AUTO_MIGRATE=false

# =============================================================================
# JWT Authentication
# =============================================================================
# Required. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Use at least 64 random hex characters
JWT_SECRET=change_this_to_a_random_64_char_hex_string
JWT_REFRESH_SECRET=change_this_to_a_different_random_64_char_hex_string

# =============================================================================
# Cookie Configuration (for refresh token)
# =============================================================================
# Required. Separate from JWT secrets. Use a different random string.
COOKIE_SECRET=change_this_to_another_random_64_char_hex_string
COOKIE_SECURE=true
# strict for same-site, lax for subdomain sharing, none for cross-site (requires secure=true)
COOKIE_SAME_SITE=lax
# Optional. Override cookie domain (e.g., .kolo.app)
COOKIE_DOMAIN=

# =============================================================================
# Server Configuration
# =============================================================================
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# =============================================================================
# CORS Configuration
# =============================================================================
# Required. Comma-separated list of allowed frontend origins (no trailing slashes).
# Must be explicit HTTPS URLs in production. Cannot be '*'.
CORS_ORIGIN=https://your-frontend-domain.com

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_MAX=100

# =============================================================================
# Nomba Payment Gateway (Required for payment processing)
# =============================================================================
NOMBA_ENVIRONMENT=live
NOMBA_PARENT_ACCOUNT_ID=your_parent_account_id
NOMBA_SUB_ACCOUNT_ID=your_sub_account_id
NOMBA_LIVE_CLIENT_ID=your_live_client_id
NOMBA_LIVE_PRIVATE_KEY=your_live_private_key
NOMBA_TEST_CLIENT_ID=
NOMBA_TEST_PRIVATE_KEY=
NOMBA_WEBHOOK_SECRET=your_nomba_webhook_secret
NOMBA_BASE_URL=https://api.nomba.com/v1
NOMBA_TRANSFER_BASE_URL=https://api.nomba.com/v1
# Required. Your webhook URL that Nomba will call back
NOMBA_WEBHOOK_URL=

# =============================================================================
# Super Admin Account (First-time setup only)
# =============================================================================
# Set these for initial deployment to create the super admin.
# After first migration and seed, these can be removed from .env
SUPER_ADMIN_EMAIL=admin@your-domain.com
SUPER_ADMIN_PASSWORD=your_strong_super_admin_password
SUPER_ADMIN_FIRST_NAME=System
SUPER_ADMIN_LAST_NAME=Administrator

# =============================================================================
# Frontend URLs
# =============================================================================
FRONTEND_URL=https://your-frontend-domain.com
ADMIN_FRONTEND_URL=https://your-admin-domain.com

# =============================================================================
# Email Configuration (Required for transactional emails)
# =============================================================================
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_WHATSAPP_NOTIFICATIONS=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user@domain.com
SMTP_PASSWORD=your_smtp_app_password
SMTP_FROM_EMAIL=noreply@your-domain.com
SMTP_FROM_NAME=Kolo
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY=60000

# =============================================================================
# Redis Configuration (Required for queues, rate limiting, token blacklist)
# =============================================================================
# For Upstash or Redis Cloud (recommended for production):
#   REDIS_URL=rediss://default:password@region-instance.upstash.io:6379
# For self-hosted Redis, use individual fields below:
#   REDIS_HOST=your-redis-host
#   REDIS_PORT=6379
#   REDIS_PASSWORD=
#   REDIS_DB=0
REDIS_URL=
QUEUE_PREFIX=KOLO

# =============================================================================
# Background Job Configuration
# =============================================================================
JOB_ATTEMPTS=3
JOB_BACKOFF_DELAY=5000
JOB_TIMEOUT=30000

# =============================================================================
# Encryption Key (For sensitive data encryption)
# =============================================================================
# Required if using encryption utilities.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# =============================================================================
# SMS & WhatsApp (Optional)
# =============================================================================
SMS_PROVIDER=
SMS_API_KEY=
SMS_API_SECRET=
WHATSAPP_PROVIDER=
WHATSAPP_API_KEY=

# =============================================================================
# Application Configuration
# =============================================================================
APP_NAME=Kolo
APP_LOGO_URL=
APP_FRONTEND_URL=https://your-frontend-domain.com
APP_SUPPORT_EMAIL=support@your-domain.com
APP_PRIVACY_URL=https://your-domain.com/privacy
APP_TERMS_URL=https://your-domain.com/terms
PRIMARY_COLOR=#00A86B
SECONDARY_COLOR=#1F2937
