# Database
DATABASE_URL=postgresql://postgres:YOUR_DATABASE_PASSWORD@localhost:5432/kolo

# JWT Authentication
JWT_SECRET=YOUR_JWT_SECRET_KEY
JWT_REFRESH_SECRET=YOUR_JWT_REFRESH_SECRET_KEY
# Cookie signing secret (separate from JWT_SECRET; required in production)
COOKIE_SECRET=YOUR_COOKIE_SECRET_KEY
# Cookie security (must be true in production; set to false for local HTTP dev)
COOKIE_SECURE=true
# SameSite policy: strict, lax, or none (none requires COOKIE_SECURE=true)
COOKIE_SAME_SITE=strict
# Cookie domain override (leave empty to default to request host)
COOKIE_DOMAIN=
PORT=4000
NODE_ENV=development

# CORS Configuration - Allow your domain (add any others comma-separated)
CORS_ORIGIN=https://kolo.telente.site

# Rate Limiting
RATE_LIMIT_MAX=100
LOG_LEVEL=info

# Nomba Payment Integration
NOMBA_ENVIRONMENT=test
NOMBA_PARENT_ACCOUNT_ID=YOUR_NOMBA_PARENT_ACCOUNT_ID
NOMBA_SUB_ACCOUNT_ID=YOUR_NOMBA_SUB_ACCOUNT_ID
NOMBA_TEST_CLIENT_ID=YOUR_NOMBA_TEST_CLIENT_ID
NOMBA_TEST_PRIVATE_KEY=YOUR_NOMBA_TEST_PRIVATE_KEY
NOMBA_LIVE_CLIENT_ID=YOUR_NOMBA_LIVE_CLIENT_ID
NOMBA_LIVE_PRIVATE_KEY=YOUR_NOMBA_LIVE_PRIVATE_KEY
NOMBA_WEBHOOK_SECRET=YOUR_NOMBA_WEBHOOK_SECRET
NOMBA_BASE_URL=https://api.nomba.com/v1
NOMBA_TRANSFER_BASE_URL=https://api.nomba.com/v1
NOMBA_WEBHOOK_URL=

# Super Admin - SET by deployment script, NOT in .env
# SUPER_ADMIN_EMAIL=admin@kolo.app
# SUPER_ADMIN_PASSWORD=YOUR_SUPER_ADMIN_PASSWORD

# Frontend URLs
# If admin is served on the same domain under /admin, use the same domain for both:
FRONTEND_URL=https://kolo.telente.site
ADMIN_FRONTEND_URL=https://kolo.telente.site

# Email Configuration
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_WHATSAPP_NOTIFICATIONS=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_smtp_app_password
SMTP_FROM_EMAIL=noreply@kolo.app
SMTP_FROM_NAME=Kolo
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY=60000

# Redis Configuration
# For local Redis, use individual fields:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# For Upstash, use REDIS_URL (overrides host/port/password/db):
#   Format: rediss://default:<password>@<region>-<instance>.upstash.io:6379
REDIS_URL=
QUEUE_PREFIX=KOLO

# SMS Provider
SMS_PROVIDER=
SMS_API_KEY=
SMS_API_SECRET=

# WhatsApp Provider
WHATSAPP_PROVIDER=
WHATSAPP_API_KEY=

# Application Configuration
APP_NAME=Kolo
APP_LOGO_URL=
APP_FRONTEND_URL=https://kolo.telente.site
APP_SUPPORT_EMAIL=support@kolo.app
APP_PRIVACY_URL=https://kolo.app/privacy
APP_TERMS_URL=https://kolo.app/terms
PRIMARY_COLOR=#00A86B
SECONDARY_COLOR=#1F2937
