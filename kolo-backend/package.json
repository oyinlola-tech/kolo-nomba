{
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit",
    "start": "node --loader tsx src/server.ts",
    "start:prod": "NODE_ENV=production node --loader tsx src/server.ts",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma migrate deploy && tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "axios": "^1.18.1",
    "bullmq": "^5.79.1",
    "date-fns": "^4.4.0",
    "fastify": "^5.8.5",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "nodemailer": "^9.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^6.0.1",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "allowScripts": {
    "prisma@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "argon2@0.44.0": true,
    "esbuild@0.28.1": true,
    "msgpackr-extract@3.0.4": true
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^8.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
