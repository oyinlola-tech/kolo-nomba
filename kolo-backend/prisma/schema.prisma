generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  GROUP_ADMIN
  MEMBER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  phone        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role       @default(MEMBER)
  status       UserStatus @default(PENDING)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  sessions          Session[]
  groupMemberships  GroupMember[]
  createdGroups     Group[]
  sentInvitations   GroupInvitation[]
  createdContributionPlans ContributionPlan[]
  payments Payment[]
  transactions Transaction[]
  requestedPayouts Payout[] @relation("requestedPayouts")
  approvedPayouts Payout[] @relation("approvedPayouts")
  payoutRecipients PayoutRecipient[]
  payoutApprovals PayoutApproval[]
  withdrawalRequests WithdrawalRequest[]
  payoutRecipientAccounts PayoutRecipientAccount[]
  notifications Notification[]
  notificationPreference NotificationPreference?
  emailLogs EmailLog[]

  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  deviceHash   String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId, deviceHash])
  @@map("sessions")
}

enum GroupStatus {
  ACTIVE
  SUSPENDED
  COMPLETED
}

enum GroupMemberRole {
  GROUP_OWNER
  GROUP_ADMIN
  MEMBER
}

enum GroupMemberStatus {
  ACTIVE
  PENDING
  REMOVED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

model Group {
  id          String        @id @default(uuid())
  name        String
  description String?
  category    String?
  location    String?
  status      GroupStatus   @default(ACTIVE)
  createdBy   String
  creator     User          @relation(fields: [createdBy], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  members     GroupMember[]
  invitations GroupInvitation[]
  contributionPlans ContributionPlan[]
  payments Payment[]
  payouts Payout[]
  payoutSchedules PayoutSchedule[]

  @@map("groups")
}

model GroupMember {
  id        String           @id @default(uuid())
  groupId   String
  group     Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  role      GroupMemberRole  @default(MEMBER)
  joinedAt  DateTime         @default(now())
  status    GroupMemberStatus @default(PENDING)
  contributions MemberContribution[]

  @@unique([groupId, userId])
  @@map("group_members")
}

model GroupInvitation {
  id        String          @id @default(uuid())
  groupId   String
  group     Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  email     String?
  phone     String?
  invitedBy String
  inviter   User            @relation(fields: [invitedBy], references: [id])
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime        @default(now())

  @@map("group_invitations")
}

enum PlanFrequency {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum PlanStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum CycleStatus {
  OPEN
  PROCESSING
  COMPLETED
  CANCELLED
}

enum ContributionStatus {
  PENDING
  PARTIAL
  PAID
  LATE
  MISSED
}

enum ReminderType {
  PAYMENT_REMINDER
  OVERDUE_REMINDER
}

model ContributionPlan {
  id          String        @id @default(uuid())
  groupId     String
  group       Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name        String
  description String?
  amount      Int
  currency    String        @default("NGN")
  frequency   PlanFrequency
  startDate   DateTime
  endDate     DateTime
  status      PlanStatus    @default(ACTIVE)
  createdBy   String
  creator     User          @relation(fields: [createdBy], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  cycles      ContributionCycle[]

  @@map("contribution_plans")
}

model ContributionCycle {
  id              String        @id @default(uuid())
  planId          String
  plan            ContributionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  cycleNumber     Int
  periodStart     DateTime
  periodEnd       DateTime
  expectedAmount  Int
  receivedAmount  Int         @default(0)
  status          CycleStatus   @default(OPEN)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  contributions   MemberContribution[]

  @@map("contribution_cycles")
}

model MemberContribution {
  id                  String             @id @default(uuid())
  cycleId             String
  cycle               ContributionCycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  groupMemberId       String
  groupMember         GroupMember        @relation(fields: [groupMemberId], references: [id])
  expectedAmount      Int
  paidAmount          Int              @default(0)
  status              ContributionStatus @default(PENDING)
  paidAt              DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  reminders           ContributionReminder[]
  payments Payment[]

  @@map("member_contributions")
}

model ContributionReminder {
  id                    String         @id @default(uuid())
  memberContributionId  String
  memberContribution    MemberContribution @relation(fields: [memberContributionId], references: [id], onDelete: Cascade)
  type                  ReminderType
  sentAt                DateTime       @default(now())
  status                String         @default("SENT")

  @@map("contribution_reminders")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

enum PaymentStatus {
  INITIALIZED
  PENDING
  SUCCESSFUL
  FAILED
  CANCELLED
  REFUNDED
}

enum TransactionType {
  CONTRIBUTION_PAYMENT
  PAYOUT
  REFUND
  FEE
}

enum TransactionStatus {
  PENDING
  SUCCESSFUL
  FAILED
}

model Payment {
  id                String        @id @default(uuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  groupId           String
  group             Group         @relation(fields: [groupId], references: [id])
  contributionId    String?
  contribution      MemberContribution? @relation(fields: [contributionId], references: [id])
  transactionId     String?   @unique
  transaction       Transaction?  @relation(fields: [transactionId], references: [id])
  amount            Int
  currency          String        @default("NGN")
  provider          String        @default("nomba")
  providerReference String?
  status            PaymentStatus @default(INITIALIZED)
  paymentMethod     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("payments")
  @@unique([provider, providerReference])
}

model Transaction {
  id        String            @id @default(uuid())
  reference String            @unique
  userId    String
  user      User              @relation(fields: [userId], references: [id])
  amount    Int
  currency  String            @default("NGN")
  type      TransactionType
  status    TransactionStatus @default(PENDING)
  metadata  Json?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  payment   Payment?

  @@map("transactions")
}

model WebhookEvent {
  id        String   @id @default(uuid())
  provider  String   @default("nomba")
  eventId   String?
  eventType String
  payload   Json
  signature String?
  status    String   @default("PENDING")
  processed Boolean  @default(false)
  processedAt DateTime?
  createdAt DateTime @default(now())

  @@map("webhook_events")
  @@unique([provider, eventId])
}

model VirtualAccount {
  id                String    @id @default(uuid())
  provider          String    @default("nomba")
  providerReference String    @unique
  accountNumber     String    @unique
  accountName       String
  bankName          String
  ownerType         OwnerType
  ownerId           String
  status            String    @default("ACTIVE")
  metadata          Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([ownerType, ownerId])
  @@map("virtual_accounts")
}

model OtpCode {
  id           String    @id @default(uuid())
  userId       String
  codeHash     String
  type         String    @default("EMAIL_VERIFICATION")
  channel      String    @default("EMAIL")
  expiresAt    DateTime
  used         Boolean   @default(false)
  attemptCount Int       @default(0)
  lockedUntil  DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId, type])
  @@map("otp_codes")
}

enum OwnerType {
  USER
  GROUP
  PLATFORM
}

enum WalletStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum AccountType {
  ASSET
  LIABILITY
  REVENUE
  EXPENSE
}

enum EntryType {
  CREDIT
  DEBIT
}

enum Direction {
  IN
  OUT
}

enum FinancialTransactionType {
  CONTRIBUTION
  TRANSFER
  PAYOUT
  FEE
  REFUND
  ADJUSTMENT
}

enum FinancialTransactionStatus {
  PENDING
  SUCCESSFUL
  FAILED
  REVERSED
}

enum ReconciliationStatus {
  MATCHED
  MISMATCHED
  PENDING
  RESOLVED
}

model Wallet {
  id        String       @id @default(uuid())
  ownerType OwnerType
  ownerId   String
  balance   Int        @default(0)
  currency  String       @default("NGN")
  status    WalletStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  accounts  LedgerAccount[]
  entries   LedgerEntry[]

  @@unique([ownerType, ownerId])
  @@map("wallets")
}

model LedgerAccount {
  id          String      @id @default(uuid())
  walletId    String
  wallet      Wallet      @relation(fields: [walletId], references: [id], onDelete: Cascade)
  accountType AccountType
  createdAt   DateTime    @default(now())

  @@map("ledger_accounts")
}

model LedgerEntry {
  id             String    @id @default(uuid())
  transactionId  String?
  financialTransaction FinancialTransaction? @relation(fields: [transactionId], references: [id])
  walletId       String
  wallet         Wallet    @relation(fields: [walletId], references: [id])
  entryType      EntryType
  amount         Int
  direction      Direction
  balanceBefore  Int
  balanceAfter   Int
  description    String?
  createdAt      DateTime  @default(now())

  @@map("ledger_entries")
}

model FinancialTransaction {
  id                  String                     @id @default(uuid())
  reference           String                     @unique
  type                FinancialTransactionType
  amount              Int
  currency            String                     @default("NGN")
  status              FinancialTransactionStatus @default(PENDING)
  sourceWalletId      String?
  destinationWalletId String?
  metadata            Json?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  ledgerEntries       LedgerEntry[]

  @@map("financial_transactions")
}

model ReconciliationRecord {
  id                String               @id @default(uuid())
  provider          String
  providerReference String
  internalReference String?
  amount            Int
  status            ReconciliationStatus @default(PENDING)
  difference        Int                @default(0)
  resolvedBy        String?
  resolvedAt        DateTime?
  createdAt         DateTime             @default(now())

  @@map("reconciliation_records")
}

enum PayoutType {
  MANUAL
  ROTATION
  CUSTOM
}

enum ScheduleFrequency {
  WEEKLY
  MONTHLY
  CUSTOM
}

enum ScheduleStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum PayoutStatus {
  PENDING
  APPROVED
  PROCESSING
  SUCCESSFUL
  COMPLETED
  FAILED
  REJECTED
  CANCELLED
}

enum RecipientStatus {
  PENDING
  PROCESSING
  SUCCESSFUL
  FAILED
}

enum ApprovalDecision {
  APPROVED
  REJECTED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model Payout {
  id          String       @id @default(uuid())
  groupId     String
  group       Group        @relation(fields: [groupId], references: [id])
  requestedBy String
  requester   User         @relation("requestedPayouts", fields: [requestedBy], references: [id])
  amount      Int
  currency    String       @default("NGN")
  type        PayoutType   @default(MANUAL)
  status      PayoutStatus @default(PENDING)
  reason      String?
  scheduleId  String?
  schedule    PayoutSchedule? @relation(fields: [scheduleId], references: [id])
  approvedBy  String?
  approver    User?        @relation("approvedPayouts", fields: [approvedBy], references: [id])
  approvedAt  DateTime?
  processedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  recipients  PayoutRecipient[]
  approvals   PayoutApproval[]

  @@map("payouts")
}

model PayoutRecipient {
  id                 String          @id @default(uuid())
  payoutId           String
  payout             Payout          @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  userId             String
  user               User            @relation(fields: [userId], references: [id])
  amount             Int
  destinationAccount String?
  recipientAccountId String?
  recipientAccount   PayoutRecipientAccount? @relation(fields: [recipientAccountId], references: [id])
  status             RecipientStatus @default(PENDING)
  providerReference  String?
  transferReference  String?
  transferStatus     String?
  retryCount         Int             @default(0)
  failureReason      String?
  processedAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@map("payout_recipients")
}

model PayoutApproval {
  id         String           @id @default(uuid())
  payoutId   String
  payout     Payout           @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  approverId String
  approver   User             @relation(fields: [approverId], references: [id])
  decision   ApprovalDecision
  comment    String?
  createdAt  DateTime         @default(now())

  @@map("payout_approvals")
}

model PayoutSchedule {
  id                String           @id @default(uuid())
  groupId           String
  group             Group            @relation(fields: [groupId], references: [id])
  type              PayoutType
  frequency         ScheduleFrequency @default(MONTHLY)
  customInterval    Int?
  amount            Int
  nextExecutionDate DateTime
  dayOfMonth        Int?
  dayOfWeek         Int?
  lastExecutedAt    DateTime?
  status            ScheduleStatus   @default(ACTIVE)
  createdBy         String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  payouts           Payout[]

  @@map("payout_schedules")
}

model PayoutRecipientAccount {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  bankName      String
  accountNumber String
  accountName   String
  provider      String   @default("nomba")
  verified      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  recipients    PayoutRecipient[]

  @@map("payout_recipient_accounts")
}

model WithdrawalRequest {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  walletId    String
  amount      Int
  destination String?
  status      WithdrawalStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("withdrawal_requests")
}

enum NotificationType {
  PAYMENT
  CONTRIBUTION
  PAYOUT
  GROUP
  SECURITY
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

model Notification {
  id        String             @id @default(uuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(PENDING)
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  deliveries NotificationDelivery[]

  @@map("notifications")
}

model NotificationPreference {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id])
  emailEnabled           Boolean  @default(true)
  smsEnabled             Boolean  @default(false)
  pushEnabled            Boolean  @default(true)
  whatsappEnabled        Boolean  @default(false)
  securityAlerts         Boolean  @default(true)
  paymentAlerts          Boolean  @default(true)
  marketingMessages      Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("notification_preferences")
}

model NotificationDelivery {
  id                String             @id @default(uuid())
  notificationId    String
  notification      Notification       @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel           NotificationChannel
  status            NotificationStatus @default(PENDING)
  provider          String?
  providerReference String?
  attempts          Int                @default(0)
  failureReason     String?
  sentAt            DateTime?
  createdAt         DateTime           @default(now())

  @@map("notification_deliveries")
}

enum BackgroundJobStatus {
  WAITING
  PROCESSING
  COMPLETED
  FAILED
}

model BackgroundJob {
  id        String              @id @default(uuid())
  jobId     String
  queue     String
  type      String
  status    BackgroundJobStatus @default(WAITING)
  progress  Int                 @default(0)
  error     String?
  payload   Json?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([jobId, queue])
  @@map("background_jobs")
}

model PlatformSetting {
  id           String   @id @default(uuid())
  key          String   @unique
  value        String
  type         String   @default("string")
  description  String?
  updatedBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("platform_settings")
}

model EmailLog {
  id                String   @id @default(uuid())
  userId            String?
  user              User?    @relation(fields: [userId], references: [id])
  template          String
  recipient         String
  status            String   @default("PENDING")
  providerReference String?
  sentAt            DateTime?
  createdAt         DateTime @default(now())

  @@map("email_logs")
}
