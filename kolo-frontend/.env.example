# Kolo Frontend Environment Configuration
# =========================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# All environment variables are prefixed with VITE_ to
# be exposed to the client-side code at build time.
# NEVER store secrets in VITE_* variables — they are
# embedded in the JavaScript bundle and visible to users.

# REQUIRED: The base URL of the Kolo backend API server.
# Example:
#   VITE_API_URL=https://api.kolo.example.com/api/v1
#   VITE_API_URL=http://localhost:4000/api/v1
VITE_API_URL=

# OPTIONAL: The display name of the application.
# Defaults to "Kolo" if not set.
# VITE_APP_NAME=Kolo
